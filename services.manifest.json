{
  "services": [
    {
      "name": "wechat_exporter",
      "kind": "managed_repo",
      "repo_url": "git@github.com:wechat-article/wechat-article-exporter.git",
      "branch": "master",
      "repo_dir": "external_tools/wechat-article-exporter",
      "install": ["yarn", "install", "--frozen-lockfile"],
      "start": ["yarn", "dev", "--host", "0.0.0.0", "--port", "3000"],
      "ready_port": 3000
    },
    {
      "name": "backend",
      "kind": "internal",
      "cwd": "backend",
      "install": ["python", "-m", "pip", "install", "-e", "."],
      "start": ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "env": {
        "WECHAT_EXPORTER_BASE_URL": "http://127.0.0.1:3000"
      },
      "ready_port": 8000
    }
  ]
}
